---
interface Props {
  title: string;
}
const { title } = Astro.props;
---
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="favicon.svg" />
    <title>{title}</title>
  </head>
  <body>
    <div class="scroll-progress" aria-hidden="true"></div>

    <div class="crt-overlay" aria-hidden="true">
      <div class="scanlines"></div>
      <div class="grain"></div>
    </div>

    <nav class="site-nav" aria-label="Section">
      <a href="#tools">Tools</a>
      <a href="#install">Install</a>
      <a href="#workflow">Workflow</a>
      <a href="#git">Git</a>
      <a href="#philosophy">Philosophy</a>
      <a href="#review-deepseek">Reviews</a>
      <a href="#changelog">Changelog</a>
      <a href="#links">Links</a>
    </nav>

    <slot />

    <script>
      const updateScroll = () => {
        const h = document.documentElement;
        const pct = h.scrollTop / (h.scrollHeight - h.clientHeight);
        h.style.setProperty("--scroll", String(isNaN(pct) ? 0 : pct));

        const nav = document.querySelector(".site-nav");
        if (nav) {
          const hero = document.getElementById("hero");
          const heroBottom = hero ? hero.getBoundingClientRect().bottom : 0;
          nav.classList.toggle("is-visible", heroBottom < 0);
        }
      };
      updateScroll();
      window.addEventListener("scroll", updateScroll, { passive: true });

      const revealObserver = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add("is-visible");
            revealObserver.unobserve(entry.target);
          }
        });
      }, { threshold: 0.1, rootMargin: "0px 0px -40px 0px" });

      document.querySelectorAll(".reveal").forEach((el) => revealObserver.observe(el));

      // Scroll-spy active link
      const navLinks = document.querySelectorAll(".site-nav a");
      const sections = document.querySelectorAll("section[id]");
      const spyObserver = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            const id = entry.target.id;
            navLinks.forEach((link) => {
              link.classList.toggle("is-active", link.getAttribute("href") === `#${id}`);
            });
          }
        });
      }, { threshold: 0, rootMargin: "-40% 0px -55% 0px" });

      sections.forEach((s) => spyObserver.observe(s));

      // Spotlight mouse tracking
      document.querySelectorAll(".tool-card, .pipeline-step, .git-step").forEach((card) => {
        card.addEventListener("mousemove", (e) => {
          const rect = card.getBoundingClientRect();
          const x = ((e.clientX - rect.left) / rect.width) * 100;
          const y = ((e.clientY - rect.top) / rect.height) * 100;
          card.style.setProperty("--sx", `${x}%`);
          card.style.setProperty("--sy", `${y}%`);
        });
      });
    </script>
  </body>
</html>

<style is:global>
  @import "../styles/global.css";
</style>
