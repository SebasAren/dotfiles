#!/usr/bin/env bash
# Sync personal Homebrew packages with the Brewfile in the dotfiles repo.
#
# Usage:
#   brew-sync              # Regenerate Brewfile from installed packages
#   brew-sync install      # Install packages from Brewfile (brew bundle)
#   brew-sync sync         # Regenerate + install (full sync)
#
# On Bluefin, system packages from /usr/share/ublue-os/homebrew/*.Brewfile
# are excluded so only your personal additions are tracked.

set -euo pipefail

BREWFILE="${HOME}/Brewfile"
SYSTEM_DIR="/usr/share/ublue-os/homebrew"

usage() {
  sed -n '2,/^$/p' "$0" | sed 's/^# //' | sed 's/^#//'
  exit 0
}

# --- Subcommand: install ---
cmd_install() {
  echo "Installing from Brewfile..."
  brew bundle
  echo "Done."
}

# --- Subcommand: regenerate Brewfile ---
cmd_sync() {
  if [[ ! -d "$SYSTEM_DIR" ]]; then
    echo "Warning: System Brewfiles not found at $SYSTEM_DIR" >&2
    echo "Generating full Brewfile without diffing." >&2
    SYSTEM_FORMULAS=""
    SYSTEM_CASKS=""
  else
    SYSTEM_FORMULAS=$(cat "$SYSTEM_DIR"/*.Brewfile 2>/dev/null \
      | grep -E '^brew ' | sed "s/^brew ['\"]//;s/['\"].*$//" | sort -u)
    SYSTEM_CASKS=$(cat "$SYSTEM_DIR"/*.Brewfile 2>/dev/null \
      | grep -E '^cask ' | sed "s/^cask ['\"]//;s/['\"].*$//" | sort -u)
  fi

  # Get top-level (explicitly installed) formulas
  LEAVES=$(brew leaves 2>/dev/null | sort)

  # Filter out system-managed formulas
  PERSONAL_FORMULAS=$(comm -23 <(echo "$LEAVES") <(echo "$SYSTEM_FORMULAS" | sort))

  # Get installed casks, filter system-managed
  INSTALLED_CASKS=$(brew list --cask -1 2>/dev/null | sort)
  PERSONAL_CASKS=$(comm -23 <(echo "$INSTALLED_CASKS") <(echo "$SYSTEM_CASKS" | sort))

  # Generate Brewfile
  cat > "$BREWFILE" << 'HEADER'
# Personal Homebrew packages (not managed by Bluefin system Brewfiles)
# Regenerate: `brew-sync` or `brew-sync sync`
#
# These are explicitly installed packages that aren't in:
#   /usr/share/ublue-os/homebrew/*.Brewfile

HEADER

  if [[ -n "$PERSONAL_FORMULAS" ]]; then
    echo "# CLI tools & development" >> "$BREWFILE"
    while IFS= read -r pkg; do
      echo "brew \"$pkg\"" >> "$BREWFILE"
    done <<< "$PERSONAL_FORMULAS"
    echo "" >> "$BREWFILE"
  fi

  if [[ -n "$PERSONAL_CASKS" ]]; then
    echo "# Fonts & GUI apps" >> "$BREWFILE"
    while IFS= read -r pkg; do
      echo "cask \"$pkg\"" >> "$BREWFILE"
    done <<< "$PERSONAL_CASKS"
  fi

  COUNT_F=$(echo "$PERSONAL_FORMULAS" | grep -c . || true)
  COUNT_C=$(echo "$PERSONAL_CASKS" | grep -c . || true)
  echo "Brewfile updated: $BREWFILE ($COUNT_F formulas, $COUNT_C casks)"
}

# --- Main ---
ACTION="${1:-sync}"

case "$ACTION" in
  sync)
    cmd_sync
    ;;
  install)
    cmd_install
    ;;
  full)
    cmd_sync
    cmd_install
    ;;
  -h|--help|help)
    usage
    ;;
  *)
    echo "Unknown action: $ACTION" >&2
    echo "Usage: brew-sync [sync|install|full]" >&2
    exit 1
    ;;
esac
