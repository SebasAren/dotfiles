#!/usr/bin/env bash
# jj-review: Set up and tear down the "brain" workflow for local code review.
#
# Usage:
#   jj-review <change-id>          Set up: duplicate change, insert brain commit
#   jj-review <from>::<to>         Set up: duplicate range, squash into one, insert brain
#   jj-review --teardown           Tear down: abandon empty dup, clean up graph
#   jj-review --teardown --keep    Tear down: keep brain (rebase onto main)
#
# See: https://ben.gesoff.uk/posts/reviewing-large-changes-with-jj/
set -euo pipefail

# ── Colors ──────────────────────────────────────────────────────────
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
BOLD='\033[1m'
RESET='\033[0m'

info()  { echo -e "${CYAN}ℹ${RESET} $*"; }
ok()    { echo -e "${GREEN}✔${RESET} $*"; }
warn()  { echo -e "${YELLOW}⚠${RESET} $*"; }
err()   { echo -e "${RED}✖${RESET} $*" >&2; }

# ── Setup (single change) ──────────────────────────────────────────
setup_single() {
  local change_id="$1"

  local resolved
  resolved=$(jj log -r "$change_id" -T 'change_id.short()' --no-graph 2>/dev/null | head -1)

  if [[ -z "$resolved" ]]; then
    err "Change '$change_id' not found. Run 'jj log' to see available revisions."
    exit 1
  fi

  local is_immutable
  is_immutable=$(jj log -r "$change_id" -T 'if(immutable, "immutable", "mutable")' --no-graph 2>/dev/null | head -1)

  info "Setting up review for ${BOLD}${resolved}${RESET} (${is_immutable})"

  local dup_id
  dup_id=$(jj duplicate "$change_id" 2>&1 | grep -oP '\bas \K\w+' | head -1)

  if [[ -z "$dup_id" ]]; then
    err "Failed to duplicate change. jj output:"
    jj duplicate "$change_id" 2>&1
    exit 1
  fi

  ok "Duplicated ${resolved} → ${dup_id}"
  create_brain "$change_id" "$dup_id"
}

# ── Setup (range of changes) ───────────────────────────────────────
setup_range() {
  local range="$1"

  # Validate the range — make sure it resolves to at least one commit
  local count
  local ids
  ids=$(jj log -r "$range" -T 'change_id.short() ++ "\n"' --no-graph 2>/dev/null)
  count=$(echo "$ids" | grep -c . || true)

  if [[ "$count" -eq 0 ]]; then
    err "Range '$range' resolves to no commits. Run 'jj log' to see available revisions."
    exit 1
  fi

  # Get the first and last commit in the range (log outputs newest-first)
  local first_id last_id
  last_id=$(echo "$ids" | head -1)
  first_id=$(echo "$ids" | tail -1)

  info "Setting up review for ${BOLD}${count}${RESET} commits (${first_id}..${last_id})"

  # Duplicate the range
  local dup_ids
  dup_ids=$(jj duplicate "$range" 2>&1 | grep -oP '\bas \K\w+')

  if [[ -z "$dup_ids" ]]; then
    err "Failed to duplicate range. jj output:"
    jj duplicate "$range" 2>&1
    exit 1
  fi

  # Get the first duplicate (bottom of stack) — that's our squashed target
  local first_dup
  first_dup=$(echo "$dup_ids" | tail -1)

  ok "Duplicated ${count} commits"

  # Squash all duplicates into the first one (bottom-up)
  info "Squashing duplicates into single review commit..."
  local dup_list
  dup_list=$(echo "$dup_ids" | head -n -1)
  for id in $dup_list; do
    jj squash --from "$id" --to "$first_dup" -m "" >/dev/null 2>&1
    jj abandon "$id" >/dev/null 2>&1 || true
  done

  # Now we have one squashed duplicate — edit it
  jj edit "$first_dup" >/dev/null 2>&1

  create_brain "$last_id" "$first_dup"
}

# ── Create brain commit ────────────────────────────────────────────
create_brain() {
  local original_id="$1"
  local dup_id="$2"

  jj edit "$dup_id" >/dev/null 2>&1

  local desc
  desc=$(jj log -r "$original_id" -T 'description.first_line()' --no-graph 2>/dev/null | head -1)
  desc="${desc:-review}"
  local brain_msg="review: ${desc}"

  jj new --no-edit --insert-before @ -m "$brain_msg" >/dev/null 2>&1

  local brain_id
  brain_id=$(jj log -r '@-' -T 'change_id.short()' --no-graph 2>/dev/null | head -1)

  ok "Created brain commit: ${brain_msg}"
  echo ""
  echo -e "${BOLD}Ready to review.${RESET}"
  echo ""
  echo "  Review commands:"
  echo "    jj diff --stat              # what's still unreviewed (duplicate)"
  echo "    jj show @- --stat           # what's in the brain (reviewed so far)"
  echo "    jj squash --interactive     # move approved hunks into the brain"
  echo "    jj squash --from @ --to @-  # move entire files into the brain"
  echo ""
  echo "  When done:"
  echo "    jj-review --teardown        # clean up (abandon if no changes)"
  echo "    jj-review --teardown --keep # clean up (keep brain, rebase to main)"
  echo ""
  echo -e "  Change IDs:  brain=${BOLD}${brain_id}${RESET}  duplicate=${BOLD}${dup_id}${RESET}"
  echo -e "  Original:    ${original_id}"
}

# ── Teardown ────────────────────────────────────────────────────────
teardown() {
  local keep_brain=false
  if [[ "${1:-}" == "--keep" ]]; then
    keep_brain=true
  fi

  local current_desc
  current_desc=$(jj log -r '@' -T 'description.first_line()' --no-graph 2>/dev/null | head -1)

  local brain_id dup_id

  # Case 1: We're on the duplicate (review commit is parent)
  if [[ "$current_desc" != review:* ]]; then
    local parent_desc
    parent_desc=$(jj log -r '@-' -T 'description.first_line()' --no-graph 2>/dev/null | head -1)

    if [[ "$parent_desc" == review:* ]]; then
      brain_id=$(jj log -r '@-' -T 'change_id.short()' --no-graph 2>/dev/null | head -1)
      dup_id=$(jj log -r '@' -T 'change_id.short()' --no-graph 2>/dev/null | head -1)
    fi
  fi

  # Case 2: We're on the brain commit (duplicate is child)
  if [[ -z "$brain_id" ]] && [[ "$current_desc" == review:* ]]; then
    brain_id=$(jj log -r '@' -T 'change_id.short()' --no-graph 2>/dev/null | head -1)
    dup_id=$(jj log -r '@+' -T 'change_id.short()' --no-graph 2>&1 | grep -v 'Error' | head -1)
  fi

  if [[ -z "$brain_id" ]]; then
    err "No review session found in current jj stack."
    err "Make sure you're on the brain or duplicate commit of an active review."
    exit 1
  fi

  local dup_diff
  dup_diff=$(jj diff -s -r "$dup_id" 2>/dev/null || true)
  if [[ -n "$dup_diff" ]]; then
    warn "Duplicate ${dup_id} still has unreviewed changes:"
    jj diff --stat -r "$dup_id" 2>/dev/null
    echo ""
    read -r -p "Continue teardown anyway? [y/N] " response
    if [[ ! "$response" =~ ^[Yy]$ ]]; then
      info "Teardown cancelled."
      exit 0
    fi
  fi

  if [[ "$keep_brain" == true ]]; then
    info "Rebasing brain ${brain_id} onto main..."
    jj rebase -r "$brain_id" -d main >/dev/null 2>&1
    jj abandon "$dup_id" >/dev/null 2>&1
    ok "Brain rebased onto main. Duplicate abandoned."
    echo ""
    echo -e "  Brain commit: ${BOLD}${brain_id}${RESET} (now on main)"
  else
    info "Abandoning review session..."
    jj abandon "$dup_id" "$brain_id" >/dev/null 2>&1
    ok "Review session cleaned up (brain + duplicate abandoned)."
  fi
}

# ── Main ────────────────────────────────────────────────────────────
if [[ $# -eq 0 ]]; then
  echo "Usage:"
  echo "  jj-review <change-id>       Set up brain review workflow"
  echo "  jj-review <from>::<to>      Set up review for a range of commits"
  echo "  jj-review --teardown        Tear down (abandon all)"
  echo "  jj-review --teardown --keep Tear down (keep brain, rebase to main)"
  exit 0
fi

case "${1:-}" in
  --teardown|-t)
    teardown "${2:-}"
    ;;
  --help|-h)
    echo "Usage:"
    echo "  jj-review <change-id>       Set up brain review workflow"
    echo "  jj-review <from>::<to>      Set up review for a range of commits"
    echo "  jj-review --teardown        Tear down (abandon all)"
    echo "  jj-review --teardown --keep Tear down (keep brain, rebase to main)"
    ;;
  *)
    # Check if we're already in a review session
    current=$(jj log -r '@-' -T 'description.first_line()' --no-graph 2>/dev/null | head -1)
    if [[ "$current" == review:* ]]; then
      err "Already in a review session (brain commit found at parent)."
      err "Run 'jj-review --teardown' first to clean up."
      exit 1
    fi

    # Route: range vs single
    if [[ "$1" == *"::"* ]]; then
      setup_range "$1"
    else
      setup_single "$1"
    fi
    ;;
esac
