#!/usr/bin/env bash
# jj-commit: Generate a commit message from jj diff using pi's CHEAP_MODEL,
# then create a jj commit with it.
set -euo pipefail

# Source pi model settings for CHEAP_MODEL
if [[ -f ~/.bashrc.d/pi_models ]]; then
  # shellcheck source=/dev/null
  source ~/.bashrc.d/pi_models
fi

# Get current diff (git-format by default)
diff=$(jj diff 2>/dev/null || true)

if [[ -z "$diff" ]]; then
  echo "No changes to commit." >&2
  exit 1
fi

# Conventional commit prefix instructions
conventional_prefix='Output ONLY a conventional commit message for the following diff.
Format: <type>(<scope>): <description>

Types: feat, fix, docs, style, refactor, perf, test, build, ci, chore, revert
Keep the scope concise (e.g. config, cli, docs) or omit if unclear.
Keep the description under 72 chars, imperative mood, no period.
Output ONLY the commit message. No quotes, no code fences, no explanation.

Diff:
'
prompt="${conventional_prefix}${diff}"

# Build pi arguments
pi_args=(
  "-p"
  "--no-tools"
  "--no-extensions"
  "--no-skills"
  "--no-session"
  "--no-prompt-templates"
  "--thinking" "off"
)
if [[ -n "${CHEAP_MODEL:-}" ]]; then
  pi_args+=("--model" "$CHEAP_MODEL")
fi

# Temp file for pi output
tmp_out=$(mktemp)
trap 'rm -f "$tmp_out"' EXIT

commit_msg=""

# Run pi with timeout
if timeout 30 pi "${pi_args[@]}" "$prompt" > "$tmp_out" 2>&1; then
  raw_msg=$(cat "$tmp_out")
  # Trim leading/trailing blank lines
  raw_msg=$(echo "$raw_msg" | sed -e '/./,$!d' -e ':a' -e '/^\n*$/{$d;N;ba}')
  # Check if it looks like a conventional commit
  if echo "$raw_msg" | grep -qE '^(feat|fix|docs|style|refactor|perf|test|build|ci|chore|revert)(\([a-z0-9._/-]+\))?: '; then
    commit_msg="$raw_msg"
  else
    echo "WARNING: Generated message doesn't match conventional commit format:" >&2
    echo "  $raw_msg" >&2
  fi
else
  echo "WARNING: pi failed to generate commit message." >&2
fi

# Fallback if no valid message
if [[ -z "$commit_msg" ]]; then
  files_changed=$(echo "$diff" | grep -c '^diff --git' || true)
  if [[ "$files_changed" -eq 0 ]]; then
    commit_msg="chore: update"
  elif [[ "$files_changed" -eq 1 ]]; then
    filename=$(echo "$diff" | grep -m1 '^diff --git' | sed 's|^diff --git a/||;s| b/.*||')
    commit_msg="chore: update $filename"
  else
    commit_msg="chore: update $files_changed files"
  fi
  echo "Using fallback commit message: $commit_msg" >&2
fi

jj commit -m "$commit_msg"
