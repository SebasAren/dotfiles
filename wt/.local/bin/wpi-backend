#!/usr/bin/env bash
set -euo pipefail

# wpi - Worktree + Pi: create worktree, run pi, offer merge on exit
#
# Usage: wpi <branch> [pi-args...]
#        wpi --attach <branch>      # resume a broken/interrupted wpi session
#        wpi -h|--help
#
# Examples:
#   wpi fix-login-bug              # create worktree, start pi
#   wpi fix-login-bug --continue   # start pi and resume last session
#   wpi --attach fix-login-bug     # reattach to review/merge flow
#   wpi refactor-api --provider anthropic --model sonnet

# ── Requirements ─────────────────────────────────────────────────────────────

for _cmd in wt pi git; do
    if ! command -v "$_cmd" >/dev/null 2>&1; then
        echo "wpi requires '$_cmd' in PATH." >&2
        exit 1
    fi
done
unset _cmd

# ── Internal wt wrapper ──────────────────────────────────────────────────────
# Handles directive files so directory changes propagate both to this process
# and (via WPI_DIRECTIVE_FILE) to the parent shell.

_wt() {
    local directive_file exit_code=0
    directive_file="$(mktemp)"
    WORKTRUNK_DIRECTIVE_FILE="$directive_file" command wt "$@" || exit_code=$?
    if [[ -s "$directive_file" ]]; then
        # Source in this process so subsequent commands run in the right directory
        # shellcheck source=/dev/null
        source "$directive_file"
        # Forward to parent shell
        if [[ -n "${WPI_DIRECTIVE_FILE:-}" ]]; then
            cat "$directive_file" >> "$WPI_DIRECTIVE_FILE"
        fi
    fi
    rm -f "$directive_file"
    return "$exit_code"
}

# ── State management ─────────────────────────────────────────────────────────

_wpi_state_dir="${XDG_CACHE_HOME:-$HOME/.cache}/wpi"

# Derive a short repo identifier from the git root to avoid state collisions
_wpi_repo_id() {
    local root
    root="$(git rev-parse --show-toplevel 2>/dev/null)" || root="$PWD"
    echo -n "$root" | md5sum | head -c 8
}

# Save wpi session state so it can be resumed later
_wpi_save_state() {
    local _branch="$1" _source_branch="$2" _stage="$3"
    local repo_id
    repo_id="$(_wpi_repo_id)"
    mkdir -p "$_wpi_state_dir"
    cat > "$_wpi_state_dir/${repo_id}-${_branch}.state" <<EOF
branch=${_branch}
source_branch=${_source_branch}
stage=${_stage}
pid=$$
repo_id=${repo_id}
timestamp=$(date +%s)
EOF
}

# Load wpi session state — sets branch, source_branch, stage
_wpi_load_state() {
    local repo_id
    repo_id="$(_wpi_repo_id)"
    local state_file="$_wpi_state_dir/${repo_id}-${1}.state"
    if [[ ! -f "$state_file" ]]; then
        echo "  No saved state for branch '$1'."
        return 1
    fi
    # shellcheck source=/dev/null
    source "$state_file"
}

# Clear wpi session state
_wpi_clear_state() {
    local repo_id
    repo_id="$(_wpi_repo_id)"
    rm -f "$_wpi_state_dir/${repo_id}-${1}.state"
}

# ── Helpers ──────────────────────────────────────────────────────────────────

# Read a line from user, ignoring Ctrl-C (SIGINT) and Ctrl-D (EOF)
_wpi_read() {
    local prompt="$1" __varname="$2"
    local __answer
    while true; do
        trap '' INT
        if IFS= read -r -p "$prompt" __answer; then
            trap - INT
            eval "$__varname=\"$__answer\""
            return 0
        fi
        # Ctrl-D pressed — re-prompt
        trap - INT
        echo
    done
}

# Review loop — open nvim to annotate, then feed comments to pi
_wpi_review_loop() {
    while true; do
        echo ""
        _wpi_read "  Review pi's changes before merging? [y/N] " answer
        if [[ ! "$answer" =~ ^[Yy]$ ]]; then
            return 0
        fi

        echo ""
        echo "  Opening nvim in diff review mode..."
        echo "  ]q/[q: next/prev change  ]h/[h: next/prev hunk"
        echo "  <leader>gd: side-by-side diff  q: close review"
        echo "  Use <leader>ra to annotate review comments."
        echo "  Press <leader>gB to reopen the diff picker at any time."
        echo ""
        local merge_base
        merge_base="$(git merge-base "${source_branch:-main}" HEAD)"
        WPI_BASE_REF="${merge_base}" nvim -c "lua require('git_diff_review').open(vim.env.WPI_BASE_REF)"
        local review_file=".code-review.md"
        if [[ -f "$review_file" ]] && [[ -s "$review_file" ]]; then
            echo ""
            echo "  Found review comments in .code-review.md"
            echo ""
            cat "$review_file"
            echo ""
            _wpi_read "  Reopen pi to apply review comments? [Y/n] " apply
            if [[ "$apply" =~ ^[Nn]$ ]]; then
                echo ""
                echo "  Skipping. Comments saved in .code-review.md"
                rm -f "$review_file"
                return 0
            fi

            echo ""
            echo "  Reopening pi with review comments..."
            echo ""
            pi "@$review_file" "Apply these review comments. Fix each issue. IMPORTANT: Do NOT call 'wt merge' yourself. Only fix the code."
            echo ""
            echo "  Review comments applied. Continuing review loop..."
            rm -f "$review_file"
            # Loop back — user can review again or proceed to merge
        else
            echo ""
            echo "  No review comments saved. Skipping."
            rm -f "$review_file"
            return 0
        fi
    done
}

# Retry loop for wt merge with automatic pi reopen on failure
_wpi_merge_loop() {
    local merge_target="$1"
    local merge_output merge_exit tmpfile prompt_file

    while true; do
        merge_exit=0
        tmpfile="$(mktemp)"
        _wt merge ${merge_target:+"$merge_target"} > "$tmpfile" 2>&1 || merge_exit=$?
        # Strip ANSI escape codes so pi gets clean text
        merge_output="$(sed 's/\x1b\[[0-9;]*[a-zA-Z]//g' "$tmpfile")"
        rm -f "$tmpfile"

        if [[ $merge_exit -eq 0 ]]; then
            echo "$merge_output"
            return 0
        fi

        # Merge failed — show the error and reopen pi to fix it
        echo ""
        echo "  ───────────────────────────────────────"
        echo "  wt merge failed (exit $merge_exit)"
        echo "  ───────────────────────────────────────"
        echo ""
        echo "$merge_output"
        echo ""
        echo "  Reopening pi to resolve the merge error..."
        echo ""

        local current_branch
        current_branch="$(git branch --show-current 2>/dev/null || echo '???')"
        prompt_file="$(mktemp)"
        {
            echo "You are in a git worktree on branch '${current_branch}'. We tried to run 'wt merge' to squash-merge this branch back, but it failed with exit code ${merge_exit}."
            echo ''
            echo 'Here is the full output:'
            echo '```'
            echo "$merge_output"
            echo '```'
            echo ''
            echo 'Diagnose the failure and fix it. Common causes:'
            echo '- Test or lint failures in pre-merge hooks — fix the code so they pass'
            echo '- Rebase conflicts — resolve the conflicts and complete the rebase'
            echo '- Uncommitted changes that need to be committed or reverted'
            echo '- Staged but uncommitted files — check git status and commit them'
            echo ''
            echo 'After fixing, the user will re-run the merge.'
        } > "$prompt_file"

        echo ""
        echo "IMPORTANT: Do NOT call 'wt merge' yourself. Only fix the code/commits." >> "$prompt_file"
        echo "The user will run the merge after you fix the issue." >> "$prompt_file"
        pi "@$prompt_file"
        rm -f "$prompt_file"

        echo ""
        _wpi_read "  Retry merge? [Y/n] " retry
        if [[ "$retry" =~ ^[Nn]$ ]]; then
            echo ""
            echo "  Merge aborted. Fix manually and run: wt merge"
            echo "  Or reattach with: wpi --attach ${branch:-<branch>}"
            return 1
        fi
        # Loop back — merge_exit is reset at the top
    done
}

# ── Usage ────────────────────────────────────────────────────────────────────

_show_help() {
    echo "Usage: wpi <branch> [pi-args...]"
    echo "       wpi --attach <branch>      # resume interrupted session"
    echo ""
    echo "Create a worktree, start pi, offer merge on exit."
    echo "After pi exits, you'll be prompted to merge the worktree"
    echo "back to the originating branch (with squash + rebase)."
    echo ""
    echo "If you break out (Ctrl-C, terminal close, etc), reattach with:"
    echo "  wpi --attach <branch>"
    echo ""
    echo "Examples:"
    echo "  wpi fix-login-bug"
    echo "  wpi fix-login-bug --continue"
    echo "  wpi --attach fix-login-bug"
    echo "  wpi refactor-api --provider anthropic"
}

# ── Main ─────────────────────────────────────────────────────────────────────

# State variables — set by _wpi_load_state or the normal flow,
# read by _wpi_review_loop / _wpi_merge_loop via dynamic scoping.
branch=""
source_branch=""

# --attach: resume a broken/interrupted session
if [[ "${1:-}" == "--attach" ]]; then
    if [[ -z "${2:-}" ]]; then
        echo "Usage: wpi --attach <branch>"
        echo ""
        echo "Resume a broken or interrupted wpi session."
        echo "Lists active sessions if no branch given."
        echo ""

        if [[ -d "$_wpi_state_dir" ]]; then
            current_repo_id="$(_wpi_repo_id)"
            found=0
            for f in "$_wpi_state_dir"/*.state; do
                [[ -f "$f" ]] || continue
                file_repo_id="$(grep -oP 'repo_id=\K\w+' "$f" 2>/dev/null || echo "")"
                [[ "$file_repo_id" == "$current_repo_id" ]] || continue
                found=1
                name="$(basename "$f" .state)"
                name="${name#"$current_repo_id"-}"
                age=$(( $(date +%s) - $(grep -oP 'timestamp=\K\d+' "$f" 2>/dev/null || echo 0) ))
                stage="$(grep -oP 'stage=\K\w+' "$f" 2>/dev/null || echo "?")"
                echo "  ${name}  (stage: ${stage}, ${age}s ago)"
            done
            if [[ $found -eq 0 ]]; then
                echo "  No active wpi sessions."
            fi
        else
            echo "  No active wpi sessions."
        fi
        exit 0
    fi

    branch="$2"
    if ! _wpi_load_state "$branch"; then
        exit 1
    fi

    # Switch to the worktree
    _wt switch "$branch" || exit 1

    echo ""
    echo "  Reattached to wpi session for '${branch}'"
    echo "  (source: ${source_branch:-unknown}, stage: ${stage:-review})"
    echo ""

    # Resume from the saved stage
    case "${stage:-review}" in
        review)
            if command -v nvim >/dev/null 2>&1; then
                _wpi_review_loop
            fi
            current_branch="$(git branch --show-current 2>/dev/null || echo "???")"
            echo ""
            echo "  ───────────────────────────────────────"
            echo "  Review complete in '${current_branch}'"
            echo "  ───────────────────────────────────────"
            echo ""
            merge_target="${source_branch:-default branch}"
            _wpi_read "  Merge back to '${merge_target}'? [y/N] " answer
            if [[ "$answer" =~ ^[Yy]$ ]]; then
                _wpi_save_state "$branch" "${source_branch:-}" "merge"
                _wpi_merge_loop "${source_branch:-}"
            else
                echo ""
                echo "  Worktree kept. Merge later with: wt merge"
            fi
            ;;
        merge)
            _wpi_merge_loop "${source_branch:-}"
            ;;
        *)
            echo "  Unknown stage '${stage}'. Starting review..."
            if command -v nvim >/dev/null 2>&1; then
                _wpi_review_loop
            fi
            ;;
    esac

    _wpi_clear_state "$branch"
    exit 0
fi

if [[ $# -eq 0 ]] || [[ "$1" == "-h" ]] || [[ "$1" == "--help" ]]; then
    _show_help
    exit 0
fi

branch="$1"
shift

# Remember the originating branch so we can merge back to it later
source_branch="$(git branch --show-current 2>/dev/null)"

# Create worktree and switch to it.
# If branch already has a worktree, wt switch just navigates to it.
if ! _wt switch --create "$branch"; then
    echo ""
    echo "  Could not create worktree for '$branch'."
    _wpi_read "  Switch to existing worktree? [y/N] " answer
    if [[ "$answer" =~ ^[Yy]$ ]]; then
        _wt switch "$branch" || exit 1
    else
        exit 1
    fi
fi

# Save state so we can reattach if interrupted
_wpi_save_state "$branch" "$source_branch" "pi"

# Start pi in the worktree.
# On first start (no extra args), just launch pi. Otherwise pass args and
# IMPORTANT: Tell the agent to NEVER call wt merge itself.
if [[ $# -eq 0 ]]; then
    echo ""
    echo "  Starting pi in worktree for '${branch}'..."
    echo "  (reattach with: wpi --attach ${branch})"
    echo ""
    pi
else
    pi "$@" "IMPORTANT: Do NOT call 'wt merge' yourself. Only fix the code. The user will run the merge manually when ready."
fi
pi_exit=$?

# Review loop: let user annotate changes, then feed back to pi
_wpi_save_state "$branch" "$source_branch" "review"
if command -v nvim >/dev/null 2>&1; then
    _wpi_review_loop
fi

# After review (or skip), offer merge
current_branch="$(git branch --show-current 2>/dev/null || echo "???")"
echo ""
echo "  ───────────────────────────────────────"
echo "  pi exited (code $pi_exit) in '${current_branch}'"
echo "  ───────────────────────────────────────"
echo ""
merge_target="${source_branch:-default branch}"
_wpi_read "  Merge back to '${merge_target}'? [y/N] " answer

if [[ "$answer" =~ ^[Yy]$ ]]; then
    _wpi_save_state "$branch" "$source_branch" "merge"
    _wpi_merge_loop "${source_branch:-}"
else
    echo ""
    echo "  Worktree kept. Merge later with:"
    echo "    wt merge ${source_branch:+$source_branch }"
    echo "  Or reattach the full flow with:"
    echo "    wpi --attach ${branch}"
fi

_wpi_clear_state "$branch"
