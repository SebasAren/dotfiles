#!/usr/bin/env bash
set -euo pipefail

# wpi - Worktree + Pi: create worktree, then run pi in a TUI loop
#
# Usage: wpi [options] [<branch>] [pi-args...]
#        wpi -h|--help
#
# Options:
#   --claude    Use claude instead of pi as the agent
#
# If <branch> is given, creates a worktree for it, then opens a TUI
# where you can cycle through: Pi → Review → Merge.
# If omitted, just opens the TUI in the current worktree.

_self_dir="$(cd "$(dirname "$0")" && pwd)"
_tui_src="$_self_dir/../share/wpi-tui/src/index.ts"

if [[ "${1:-}" == "-h" ]] || [[ "${1:-}" == "--help" ]]; then
    echo "Usage: wpi [--claude] [<branch>] [pi-args...]"
    echo ""
    echo "With <branch>: create a worktree, open a TUI loop: Pi → Review → Merge."
    echo "Without <branch>: open the TUI in the current worktree."
    echo ""
    echo "Examples:"
    echo "  wpi fix-login-bug"
    echo "  wpi --claude fix-login-bug"
    echo "  wpi refactor-api --provider anthropic --model sonnet"
    echo "  wpi"
    exit 0
fi

# ── Parse --claude flag ───────────────────────────────────────────
_agent="pi"
if [[ "${1:-}" == "--claude" ]]; then
    _agent="claude"
    shift
fi

for _cmd in git bun; do
    if ! command -v "$_cmd" >/dev/null 2>&1; then
        echo "wpi requires '$_cmd' in PATH." >&2
        exit 1
    fi
done
unset _cmd

if ! command -v "$_agent" >/dev/null 2>&1; then
    echo "wpi requires '$_agent' in PATH." >&2
    exit 1
fi

# Directive file for wt shell integration (cleaned up on exit)
directive_file="$(mktemp)"
trap 'rm -f "$directive_file"' EXIT

export WPI_AGENT="$_agent"
unset _agent

if [[ $# -gt 0 ]]; then
    # ── Branch mode: create worktree, then launch TUI ──────────
    for _cmd in wt; do
        if ! command -v "$_cmd" >/dev/null 2>&1; then
            echo "wpi requires '$_cmd' in PATH." >&2
            exit 1
        fi
    done
    unset _cmd

    branch="$1"
    shift

    source_branch="$(git branch --show-current 2>/dev/null || echo '')"
    if ! WORKTRUNK_DIRECTIVE_FILE="$directive_file" wt switch --create "$branch"; then
        echo "  Could not create worktree for '$branch'." >&2
        exit 1
    fi
    # Source the directive to cd into the worktree in this process
    if [[ -s "$directive_file" ]]; then
        # shellcheck source=/dev/null
        source "$directive_file"
    fi

    export WPI_BRANCH="$branch"
    export WPI_SOURCE_BRANCH="$source_branch"
    export WPI_PI_ARGS="$*"
    export WPI_DIRECTIVE_FILE="$directive_file"
else
    # ── No branch: just launch TUI in current worktree ─────────
    export WPI_PI_ARGS=""
fi

exec bun run "$_tui_src"
