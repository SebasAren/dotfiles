#!/usr/bin/env bash
set -euo pipefail

# wpi - TUI frontend for Worktree + Pi workflow
#
# Usage: wpi               # show interactive TUI menu
#        wpi <branch> [..]  # run full pipeline (backward compat)
#        wpi --attach <br>  # resume interrupted session
#        wpi -h|--help
#
# The TUI lets you pick individual stages: create worktree, start pi,
# review changes, merge, or attach to a session.
# When called with arguments, delegates to wpi-backend for the full flow.

_self_dir="$(cd "$(dirname "$0")" && pwd)"
_tui_src="$_self_dir/../share/wpi-tui/src/index.ts"

if [[ $# -eq 0 ]]; then
    # No args: show TUI menu
    exec bun run "$_tui_src"
else
    # Args provided: delegate to backend for backward compatibility
    exec "$_self_dir/wpi-backend" "$@"
fi
