#!/usr/bin/env bun
// Hybrid BM25 + vector search for the LLM wiki, with Cohere Rerank via OpenRouter.
// Usage: wiki-search <query> [--context N] [--top N] [--no-rerank] [--rebuild] [--alpha N] [--semantic]

import { main } from "../lib/wiki-search/cli.ts";

const result = await main(
  process.argv.slice(2),
  process.env as Record<string, string | undefined>,
);

if (result.startsWith("No matching pages")) {
  console.log(result);
  process.exit(0);
}
if (result.startsWith("Error:")) {
  console.error(result);
  process.exit(1);
}
console.log(result);
