#!/usr/bin/env bun
/**
 * store-memory — Write conceptual observations to the wiki inbox
 *
 * Creates a markdown file in ~/Documents/wiki/raw/inbox/ with YAML frontmatter
 * (title, created, tags) for the obsidian-wiki-ingest pipeline to pick up.
 *
 * Usage:
 *   store-memory --title "My Observation" --tags agents,architecture < content.md
 *   store-memory --title "Short Note" --tags quick "Inline content here"
 *
 * Library usage:
 *   import { createMemoryNote } from "./store-memory";
 *   const path = createMemoryNote({ title, content, tags });
 */

import { existsSync, mkdirSync, writeFileSync } from "node:fs";
import { homedir } from "node:os";
import { join, resolve } from "node:path";

const DEFAULT_OUTPUT_DIR = join(homedir(), "Documents", "wiki", "raw", "inbox");

export interface CreateMemoryNoteOptions {
	title: string;
	content: string;
	tags: string[];
	outputDir?: string;
}

/**
 * Slugify a string for use in filenames.
 * Converts to lowercase, replaces non-alphanumeric chars with hyphens,
 * collapses consecutive hyphens, strips leading/trailing hyphens.
 */
function slugify(text: string): string {
	return text
		.toLowerCase()
		.replace(/[^a-z0-9]+/g, "-")
		.replace(/^-+|-+$/g, "");
}

/**
 * Create a memory note markdown file in the wiki inbox.
 *
 * @returns The absolute path to the created file.
 */
export function createMemoryNote(options: CreateMemoryNoteOptions): string {
	const { title, content, tags } = options;

	if (!title || title.trim().length === 0) {
		throw new Error("title must be a non-empty string");
	}

	const outputDir = options.outputDir ?? DEFAULT_OUTPUT_DIR;

	// Ensure output directory exists
	if (!existsSync(outputDir)) {
		mkdirSync(outputDir, { recursive: true });
	}

	// Generate date prefix and slug
	const today = new Date();
	const datePrefix = today.toISOString().slice(0, 10); // YYYY-MM-DD
	const slug = slugify(title);
	let fileName = `${datePrefix}-${slug}.md`;
	let filePath = join(outputDir, fileName);

	// Handle slug collision by appending a counter
	let counter = 1;
	while (existsSync(filePath)) {
		fileName = `${datePrefix}-${slug}-${counter}.md`;
		filePath = join(outputDir, fileName);
		counter++;
	}

	// Build the YAML frontmatter
	const created = today.toISOString();
	const yamlTitle = JSON.stringify(title);
	const frontmatter = tags.length > 0
		? [
			"---",
			`title: ${yamlTitle}`,
			`created: ${created}`,
			"tags:",
			...tags.map((t) => `  - ${t}`),
			"---",
		].join("\n")
		: [
			"---",
			`title: ${yamlTitle}`,
			`created: ${created}`,
			"tags: []",
			"---",
		].join("\n");

	// Write the file
	const fileContent = `${frontmatter}\n\n${content}\n`;
	writeFileSync(filePath, fileContent, "utf8");

	return resolve(filePath);
}

// CLI entry point
if (import.meta.path === resolve(process.argv[1] ?? "")) {
	const args = process.argv.slice(2);

	let title = "";
	let tags: string[] = [];
	let content = "";

	// Collect all positional arguments (join them as content)
	const positionalArgs: string[] = [];

	// Parse CLI arguments
	for (let i = 0; i < args.length; i++) {
		if (args[i] === "--title" && i + 1 < args.length) {
			title = args[++i];
		} else if (args[i] === "--tags" && i + 1 < args.length) {
			tags = args[++i].split(",").map((t) => t.trim()).filter(Boolean);
		} else if (!args[i].startsWith("--")) {
			// Positional arguments = content (all joined)
			positionalArgs.push(args[i]);
		}
	}

	content = positionalArgs.join(" ");

	// If no positional content, try stdin
	if (!content && !process.stdin.isTTY) {
		let stdinData = "";
		for await (const chunk of process.stdin) {
			stdinData += chunk;
		}
		content = stdinData.trim();
	}

	if (!title) {
		console.error("Usage: store-memory --title <title> [--tags tag1,tag2] [content]");
		console.error("       echo 'content' | store-memory --title 'My Note' --tags agents");
		process.exit(1);
	}

	const filePath = createMemoryNote({ title, content, tags });
	console.log(`Memory note created: ${filePath}`);
}
