{
  "$schema": "https://raw.githubusercontent.com/code-yeongyu/oh-my-openagent/dev/assets/oh-my-opencode.schema.json",

  // Feature flags
  "hashline_edit": true,
  "model_fallback": true,

  // Auto-retry with fallback on provider errors
  "runtime_fallback": {
    "enabled": true,
    "retry_on_errors": [400, 402, 429, 500, 502, 503, 504, 529],
    "max_fallback_attempts": 3,
    "cooldown_seconds": 60
  },

  "agents": {
    // Planning agents - GLM-5
    "prometheus": {
      "model": "zai-coding-plan/glm-5.1",
      "fallback_models": ["minimax-coding-plan/MiniMax-M2.7"]
    },
    "metis": {
      "model": "zai-coding-plan/glm-5.1",
      "fallback_models": ["minimax-coding-plan/MiniMax-M2.7"]
    },
    "momus": {
      "model": "zai-coding-plan/glm-5.1",
      "fallback_models": ["minimax-coding-plan/MiniMax-M2.7"]
    },
    "oracle": {
      "model": "opencode/mimo-v2-pro-free",
      "fallback_models": ["openrouter/xiaomi/mimo-v2-pro", "zai-coding-plan/glm-5.1", "minimax-coding-plan/MiniMax-M2.7"],
      "reasoningEffort": "xhigh"
    },
    "atlas": {
      "model": "minimax-coding-plan/MiniMax-M2.7",
      "fallback_models": ["zai-coding-plan/glm-5.1"]
    },
    "plan": {
      "model": "zai-coding-plan/glm-5.1",
      "fallback_models": ["minimax-coding-plan/MiniMax-M2.7"]
    },

    // Implementation agents - GLM-5 for orchestration, MiniMax for execution
    "sisyphus": {
      "model": "zai-coding-plan/glm-5.1",
      "fallback_models": ["minimax-coding-plan/MiniMax-M2.7"],
      "compaction": { "model": "mistral/mistral-small-latest" },
      "prompt_append": "<GLM_DELEGATION_OVERRIDE>\n## DELEGATION IS MANDATORY — YOU ARE NOT AN IMPLEMENTER\n\n**You have a strong tendency to do work yourself after exploration. RESIST THIS.**\n\nYou are an ORCHESTRATOR. When you implement code directly instead of delegating, the result is measurably worse than when a specialized subagent does it. Subagents have domain-specific configurations, loaded skills, and tuned prompts that you lack.\n\n**EVERY TIME you are about to write code or make changes directly:**\n→ STOP. Ask: 'Is there a category + skills combination for this?'\n→ If YES (almost always): delegate via `task()`\n→ If NO (extremely rare): proceed, but this should happen less than 5% of the time\n\n**YOUR SPECIFIC FAILURE MODE:** After completing exploration (explore/librarian agents return results), you have full context and feel confident. This is EXACTLY when you MUST delegate. Having context makes you a BETTER delegator, not an implementer. Your job is to write crystal-clear prompts to subagents who will execute the actual work.\n\n**SELF-CHECK before EVERY direct code change:**\n1. Am I about to write/edit code myself? → Delegate to `deep` or `unspecified-high` category instead.\n2. Is this 'too simple' to delegate? → Delegate anyway. Your 'simple fix' is slower and worse than a subagent's.\n3. Do I already have all the context? → GOOD. Use it to write a better delegation prompt.\n4. Would this take <2 lines? → Only then proceed yourself. Otherwise delegate.\n\n**The user chose an orchestrator model specifically because they want delegation and parallel execution. If you do work yourself, you are failing your purpose.**\n</GLM_DELEGATION_OVERRIDE>"
    },
    "sisyphus-junior": {
      "model": "minimax-coding-plan/MiniMax-M2.7",
      "fallback_models": ["zai-coding-plan/glm-5.1"]
    },

    // Deep autonomous work - Mimo V2 Pro (hardest task, needs best reasoning)
    "hephaestus": {
      "model": "opencode/mimo-v2-pro-free",
      "fallback_models": ["openrouter/xiaomi/mimo-v2-pro", "opencode/nemotron-3-super-free", "zai-coding-plan/glm-5.1", "minimax-coding-plan/MiniMax-M2.7"]
    },

    // Research/execution - Kimi K2.5 for comprehension, MiniMax for builds
    "librarian": {
      "model": "moonshotai/kimi-k2.5",
      "fallback_models": ["minimax-coding-plan/MiniMax-M2.7", "zai-coding-plan/glm-5.1"]
    },
    "explore": {
      "model": "opencode/nemotron-3-super-free",
      "fallback_models": ["nvidia/nemotron-3-super-120b-a12b:free", "mistral/mistral-small-latest", "minimax-coding-plan/MiniMax-M2.7"]
    },
    "multimodal-looker": {
      "model": "moonshotai/kimi-k2.5",
      "fallback_models": ["minimax-coding-plan/MiniMax-M2.7"]
    },
    "OpenCode-Builder": {
      "model": "minimax-coding-plan/MiniMax-M2.7",
      "fallback_models": ["opencode/nemotron-3-super-free", "zai-coding-plan/glm-5.1"]
    },
    "build": {
      "model": "minimax-coding-plan/MiniMax-M2.7",
      "fallback_models": ["opencode/nemotron-3-super-free", "zai-coding-plan/glm-5.1"]
    },

    // Custom project agents (prompt from .claude/agents/*.md, model overridden here)
    "gitlab-code-reviewer": {
      "model": "opencode/mimo-v2-pro-free",
      "fallback_models": ["zai-coding-plan/glm-5.1", "minimax-coding-plan/MiniMax-M2.7"]
    },
    "cross-app-impact-reviewer": {
      "model": "zai-coding-plan/glm-5.1",
      "fallback_models": ["minimax-coding-plan/MiniMax-M2.7"]
    },
    "typescript-test-engineer": {
      "model": "minimax-coding-plan/MiniMax-M2.7",
      "fallback_models": ["zai-coding-plan/glm-5.1"]
    }
  },

  "categories": {
    // Planning categories - GLM-5
    "unspecified-high": {
      "model": "zai-coding-plan/glm-5.1",
      "fallback_models": ["minimax-coding-plan/MiniMax-M2.7"]
    },
    "ultrabrain": {
      "model": "opencode/mimo-v2-pro-free",
      "fallback_models": ["opencode/nemotron-3-super-free", "zai-coding-plan/glm-5.1", "minimax-coding-plan/MiniMax-M2.7"]
    },
    "deep": {
      "model": "opencode/mimo-v2-pro-free",
      "fallback_models": ["opencode/nemotron-3-super-free", "zai-coding-plan/glm-5.1", "minimax-coding-plan/MiniMax-M2.7"]
    },

    // Implementation categories - MiniMax M2.7
    "quick": {
      "model": "minimax-coding-plan/MiniMax-M2.7",
      "fallback_models": ["zai-coding-plan/glm-5.1"]
    },
    "visual-engineering": {
      "model": "moonshotai/kimi-k2.5",
      "fallback_models": ["minimax-coding-plan/MiniMax-M2.7", "zai-coding-plan/glm-5.1"]
    },
    "writing": {
      "model": "moonshotai/kimi-k2.5",
      "fallback_models": ["minimax-coding-plan/MiniMax-M2.7"]
    },
    "unspecified-low": {
      "model": "minimax-coding-plan/MiniMax-M2.7",
      "fallback_models": ["zai-coding-plan/glm-5.1"]
    },
    "artistry": {
      "model": "moonshotai/kimi-k2.5",
      "fallback_models": ["minimax-coding-plan/MiniMax-M2.7", "zai-coding-plan/glm-5.1"]
    },

    // For truly trivial stuff
    "trivial": {
      "model": "mistral/mistral-small-latest",
      "fallback_models": ["minimax-coding-plan/MiniMax-M2.7"]
    }
  },

  "background_task": {
    "providerConcurrency": {
      "zai": 10,
      "minimax-coding-plan": 10,
      "mistral": 10,
      "opencode": 10
    },
    "circuitBreaker": {
      "enabled": true,
      "maxToolCalls": 200,
      "consecutiveThreshold": 5
    }
  }
}
