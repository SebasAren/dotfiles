{
  "$schema": "https://raw.githubusercontent.com/code-yeongyu/oh-my-openagent/dev/assets/oh-my-opencode.schema.json",

  // Feature flags
  "hashline_edit": true,
  "model_fallback": true,

  // Auto-retry with fallback on provider errors
  "runtime_fallback": {
    "enabled": true,
    "retry_on_errors": [400, 402, 429, 500, 502, 503, 504, 529],
    "max_fallback_attempts": 3,
    "cooldown_seconds": 60
  },

  "agents": {
    // Planning agents - GLM-5
    "prometheus": {
      "model": "zai-coding-plan/glm-5.1",
      "fallback_models": ["minimax-coding-plan/MiniMax-M2.7"]
    },
    "metis": {
      "model": "zai-coding-plan/glm-5.1",
      "fallback_models": ["minimax-coding-plan/MiniMax-M2.7"]
    },
    "momus": {
      "model": "opencode/mimo-v2-pro-free",
      "fallback_models": ["xiaomi/mimo-v2-pro", "zai-coding-plan/glm-5.1"]
    },
    "oracle": {
      "model": "opencode/mimo-v2-pro-free",
      "fallback_models": ["xiaomi/mimo-v2-pro", "zai-coding-plan/glm-5.1", "minimax-coding-plan/MiniMax-M2.7"],
      "reasoningEffort": "xhigh"
    },
    "atlas": {
      "model": "minimax-coding-plan/MiniMax-M2.7",
      "fallback_models": ["zai-coding-plan/glm-5.1"]
    },

    "sisyphus": {
      "model": "xiaomi/mimo-v2-omni",
      "fallback_models": ["zai-coding-plan/glm-5.1", "mistral/mistral-small-latest"],
      "compaction": { "model": "mistral/mistral-small-latest" },
      "prompt_append": "<DELEGATION_RULES>\n## YOU ARE AN ORCHESTRATOR, NOT AN IMPLEMENTER\n\n**Code work** → delegate via `task()` to specialized categories\n**Research** (docs, library behavior, config) → `librarian` agent in background\n**Codebase exploration** (patterns, structure) → `explore` agent in background\n\nDo NOT use websearch/webfetch directly. Do NOT implement code yourself.\nWrite prompts, not code. Your value is orchestration and quality control.\n</DELEGATION_RULES>"
    },
    "sisyphus-junior": {
      "model": "minimax-coding-plan/MiniMax-M2.7",
      "fallback_models": ["zai-coding-plan/glm-5.1"]
    },

    // Deep autonomous work - Mimo V2 Pro (hardest task, needs best reasoning)
    "hephaestus": {
      "model": "opencode/mimo-v2-pro-free",
      "fallback_models": ["openrouter/xiaomi/mimo-v2-pro", "opencode/nemotron-3-super-free", "zai-coding-plan/glm-5.1", "minimax-coding-plan/MiniMax-M2.7"]
    },

    // Research/execution - Kimi K2.5 for comprehension, MiniMax for builds
    "librarian": {
      "model": "xiaomi/mimo-v2-flash",
      "fallback_models": ["mistral/mistral-small-latest", "minimax-coding-plan/MiniMax-M2.7", "zai-coding-plan/glm-5.1"]
    },
    "explore": {
      "model": "xiaomi/mimi-v2-flash",
      "fallback_models": ["mistral/mistral-small-latest", "minimax-coding-plan/MiniMax-M2.7"],
      "reasoningEffort": "none"
    },
    "multimodal-looker": {
      "model": "xioami/mimo-v2-omni",
      "fallback_models": ["moonshotai/kimi-k2.5"]
    },

    // Custom project agents (prompt from .claude/agents/*.md, model overridden here)
    "gitlab-code-reviewer": {
      "model": "opencode/mimo-v2-pro-free",
      "fallback_models": ["xiaomi/mimo-v2-pro-free", "zai-coding-plan/glm-5.1"]
    },
    "cross-app-impact-reviewer": {
      "model": "zai-coding-plan/glm-5.1",
      "fallback_models": ["minimax-coding-plan/MiniMax-M2.7"]
    },
    "typescript-test-engineer": {
      "model": "minimax-coding-plan/MiniMax-M2.7",
      "fallback_models": ["zai-coding-plan/glm-5.1"]
    }
  },

  "categories": {
    // Planning categories - GLM-5
    "unspecified-high": {
      "model": "zai-coding-plan/glm-5.1",
      "fallback_models": ["minimax-coding-plan/MiniMax-M2.7"]
    },
    "ultrabrain": {
      "model": "opencode/mimo-v2-pro-free",
      "fallback_models": ["xiaomi/mimo-v2-pro", "zai-coding-plan/glm-5.1"]
    },
    "deep": {
      "model": "opencode/mimo-v2-pro-free",
      "fallback_models": ["xiaomi/mimo-v2-pro", "zai-coding-plan/glm-5.1", "minimax-coding-plan/MiniMax-M2.7"]
    },

    // Implementation categories - MiniMax M2.7
    "quick": {
      "model": "minimax-coding-plan/MiniMax-M2.7",
      "fallback_models": ["zai-coding-plan/glm-5.1"]
    },
    "visual-engineering": {
      "model": "xiaomi/mimo-v2-omni",
      "fallback_models": ["moonshotai/kimi-k2.5"]
    },
    "writing": {
      "model": "mistral/mistral-small-latest",
      "fallback_models": ["minimax-coding-plan/MiniMax-M2.7"]
    },
    "unspecified-low": {
      "model": "minimax-coding-plan/MiniMax-M2.7",
      "fallback_models": ["mistral/mistral-small-latest"]
    },
    "artistry": {
      "model": "opencode/mimo-v2-pro-free",
      "fallback_models": ["xiaomi/mimo-v2-pro", "zai-coding-plan/glm-5.1"]
    },

    // For truly trivial stuff
    "trivial": {
      "model": "mistral/mistral-small-latest",
      "fallback_models": ["minimax-coding-plan/MiniMax-M2.7"]
    }
  },

  "background_task": {
    "providerConcurrency": {
      "zai": 10,
      "minimax-coding-plan": 10,
      "mistral": 10,
      "opencode": 10
    },
    "circuitBreaker": {
      "enabled": true,
      "maxToolCalls": 200,
      "consecutiveThreshold": 5
    }
  }
}
