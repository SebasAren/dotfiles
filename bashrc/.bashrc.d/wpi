# wpi - thin shell wrapper for the wpi bin script
# Forwards directory changes from wt to the parent shell via WPI_DIRECTIVE_FILE

if command -v wpi >/dev/null 2>&1; then
    wpi() {
        command -v _ensure_secrets &>/dev/null && _ensure_secrets
        local directive_file exit_code=0
        directive_file="$(mktemp)"
        WPI_DIRECTIVE_FILE="$directive_file" command wpi "$@" || exit_code=$?
        # shellcheck source=/dev/null
        [[ -s "$directive_file" ]] && source "$directive_file"
        rm -f "$directive_file"
        return "$exit_code"
    }
fi
