# wpi - Worktree + Pi: create worktree, run pi, offer merge on exit
#
# Usage: wpi <branch> [pi-args...]
#        wpi -h|--help
#
# Examples:
#   wpi fix-login-bug              # create worktree, start pi
#   wpi fix-login-bug --continue   # start pi and resume last session
#   wpi refactor-api --provider anthropic --model sonnet

if command -v wt >/dev/null 2>&1 && command -v pi >/dev/null 2>&1; then
    wpi() {
        if [[ $# -eq 0 ]] || [[ "$1" == "-h" ]] || [[ "$1" == "--help" ]]; then
            echo "Usage: wpi <branch> [pi-args...]"
            echo ""
            echo "Create a worktree, start pi, offer merge on exit."
            echo "After pi exits, you'll be prompted to merge the worktree"
            echo "back to the originating branch (with squash + rebase)."
            echo ""
            echo "Examples:"
            echo "  wpi fix-login-bug"
            echo "  wpi fix-login-bug --continue"
            echo "  wpi refactor-api --provider anthropic"
            return 0
        fi

        local branch="$1"
        shift

        # Remember the originating branch so we can merge back to it later
        local source_branch
        source_branch="$(git branch --show-current 2>/dev/null)"

        # Create worktree and switch to it.
        # If branch already has a worktree, wt switch just navigates to it.
        if ! wt switch --create "$branch"; then
            echo ""
            echo "  Could not create worktree for '$branch'."
            read -r -p "  Switch to existing worktree? [y/N] " answer
            if [[ "$answer" =~ ^[Yy]$ ]]; then
                wt switch "$branch" || return 1
            else
                return 1
            fi
        fi

        # Start pi in the worktree.
        # On first start (no extra args), just launch pi. Otherwise pass args and
        # IMPORTANT: Tell the agent to NEVER call wt merge itself.
        if [[ $# -eq 0 ]]; then
            pi
        else
            pi "$@" "IMPORTANT: Do NOT call 'wt merge' yourself. Only fix the code. The user will run the merge manually when ready."
        fi
        local pi_exit=$?

        # Review loop: let user annotate changes, then feed back to pi
        if command -v nvim >/dev/null 2>&1; then
            _wpi_review_loop
        fi

        # After review (or skip), offer merge
        local current_branch
        current_branch="$(git branch --show-current 2>/dev/null || echo "???")"
        echo ""
        echo "  ───────────────────────────────────────"
        echo "  pi exited (code $pi_exit) in '${current_branch}'"
        echo "  ───────────────────────────────────────"
        echo ""
        local merge_target="${source_branch:-default branch}"
        read -r -p "  Merge back to '${merge_target}'? [y/N] " answer

        if [[ "$answer" =~ ^[Yy]$ ]]; then
            _wpi_merge_loop "${source_branch:-}"
        else
            echo ""
            echo "  Worktree kept. Merge later with: wt merge"
        fi
    }
fi

# Helper: review loop — open nvim to annotate, then feed comments to pi
if command -v nvim >/dev/null 2>&1; then
    _wpi_review_loop() {
        while true; do
            echo ""
            read -r -p "  Review pi's changes before merging? [y/N] " answer
            if [[ ! "$answer" =~ ^[Yy]$ ]]; then
                return 0
            fi

            # Open nvim in the worktree for review.
            # code-review.nvim keymaps: <leader>ra to annotate, <leader>rs to save.
            echo ""
            echo "  Opening nvim for review..."
            echo "  Keymaps: <leader>ra = annotate, <leader>rd = delete, <leader>rl = list, <leader>rs = save, :wq = done"
            echo ""
            nvim .

            # Check if .code-review.md was created with content
            local review_file=".code-review.md"
            if [[ -f "$review_file" ]] && [[ -s "$review_file" ]]; then
                echo ""
                echo "  Found review comments in .code-review.md"
                echo ""
                cat "$review_file"
                echo ""
                read -r -p "  Reopen pi to apply review comments? [Y/n] " apply
                if [[ "$apply" =~ ^[Nn]$ ]]; then
                    echo ""
                    echo "  Skipping. Comments saved in .code-review.md"
                    rm -f "$review_file"
                    return 0
                fi

                # Reopen pi with review file as context
                echo ""
                echo "  Reopening pi with review comments..."
                echo ""
                pi "@$review_file" "Apply these review comments. Fix each issue. IMPORTANT: Do NOT call 'wt merge' yourself. Only fix the code."
                rm -f "$review_file"

                # Loop back — user can review again or proceed to merge
            else
                echo ""
                echo "  No review comments saved. Skipping."
                rm -f "$review_file"
                return 0
            fi
        done
    }
fi

# Helper: retry loop for wt merge with automatic pi reopen on failure
if command -v wt >/dev/null 2>&1 && command -v pi >/dev/null 2>&1; then
    _wpi_merge_loop() {
        local source_branch="$1"
        local merge_output merge_exit tmpfile prompt_file

        while true; do
            merge_exit=0
            tmpfile="$(mktemp)"
            # Run wt merge in the current shell (not a subshell) so its
            # directive-file cd takes effect. Redirect to a temp file to
            # capture output for error reporting.
            wt merge ${source_branch:+"$source_branch"} > "$tmpfile" 2>&1 || merge_exit=$?
            # Strip ANSI escape codes so pi gets clean text
            merge_output="$(sed 's/\x1b\[[0-9;]*[a-zA-Z]//g' "$tmpfile")"
            rm -f "$tmpfile"

            if [[ $merge_exit -eq 0 ]]; then
                echo "$merge_output"
                return 0
            fi

            # Merge failed — show the error and reopen pi to fix it
            echo ""
            echo "  ───────────────────────────────────────"
            echo "  wt merge failed (exit $merge_exit)"
            echo "  ───────────────────────────────────────"
            echo ""
            echo "$merge_output"
            echo ""
            echo "  Reopening pi to resolve the merge error..."
            echo ""

            # Build prompt in a temp file to avoid shell interpolation
            # issues and OS argument length limits with large merge output.
            # Pass as context file so pi includes it but stays interactive.
            local current_branch
            current_branch="$(git branch --show-current 2>/dev/null || echo '???')"
            prompt_file="$(mktemp)"
            {
                echo "You are in a git worktree on branch '${current_branch}'. We tried to run 'wt merge' to squash-merge this branch back, but it failed with exit code ${merge_exit}."
                echo ''
                echo 'Here is the full output:'
                echo '```'
                echo "$merge_output"
                echo '```'
                echo ''
                echo 'Diagnose the failure and fix it. Common causes:'
                echo '- Test or lint failures in pre-merge hooks — fix the code so they pass'
                echo '- Rebase conflicts — resolve the conflicts and complete the rebase'
                echo '- Uncommitted changes that need to be committed or reverted'
                echo ''
                echo 'After fixing, the user will re-run the merge.'
            } > "$prompt_file"

            # Pass as context file to include in message, but stay interactive.
            # IMPORTANT: Tell the agent to NEVER call wt merge itself.
            echo "" 
            echo "IMPORTANT: Do NOT call 'wt merge' yourself. Only fix the code/commits." >> "$prompt_file"
            echo "The user will run the merge after you fix the issue." >> "$prompt_file"
            pi "@$prompt_file"
            rm -f "$prompt_file"

            echo ""
            read -r -p "  Retry merge? [Y/n] " retry
            if [[ "$retry" =~ ^[Nn]$ ]]; then
                echo ""
                echo "  Merge aborted. Fix manually and run: wt merge"
                return 1
            fi
            # Loop back — merge_exit is reset at the top
        done
    }
fi
