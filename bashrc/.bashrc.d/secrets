#!/bin/bash
# Resolve API keys from Proton Pass at shell init.
# Fails silently if pass-cli is not installed or not logged in.
_secrets_tpl="$HOME/.secrets.tpl"
if command -v pass-cli &>/dev/null && [ -f "$_secrets_tpl" ]; then
  _resolved="$(pass-cli inject -i "$_secrets_tpl" 2>/dev/null)"
  if [ $? -eq 0 ] && [ -n "$_resolved" ]; then
    eval "$_resolved"
  fi
fi
unset _secrets_tpl _resolved
