#!/bin/bash
# Lazy secret resolution from Proton Pass.
# Only runs when pi, nvim, or wt actually need the API keys.

mkdir -p "$HOME/.local/share/proton-pass-cli"
export PROTON_PASS_KEY_PROVIDER=fs

_secrets_resolved=false

_ensure_secrets() {
  if $_secrets_resolved; then return; fi
  _secrets_resolved=true

  local tpl="$HOME/.secrets.tpl"
  if command -v pass-cli &>/dev/null && [ -f "$tpl" ]; then
    local resolved
    resolved="$(pass-cli inject -i "$tpl" 2>/dev/null)" && [ -n "$resolved" ] && eval "$resolved"
  fi
}

# Wrapper: resolve secrets before launching these tools
if command -v nvim &>/dev/null; then
  _nvim_bin="$(command -v nvim)"
  nvim() { _ensure_secrets; command "$_nvim_bin" "$@"; }
fi

if command -v pi &>/dev/null; then
  _pi_bin="$(command -v pi)"
  pi() { _ensure_secrets; command "$_pi_bin" "$@"; }
fi
