#!/bin/bash
# Resolve API keys from Proton Pass at shell init.
# Fails silently if pass-cli is not installed or not logged in.
# Ensure data directory exists — pass-cli doesn't create it on first login.
mkdir -p "$HOME/.local/share/proton-pass-cli"

# Use filesystem key provider — the default (kernel keyring) is wiped on reboot,
# and dbus (GNOME Keyring) doesn't auto-unlock with auto-login.
export PROTON_PASS_KEY_PROVIDER=fs

_secrets_tpl="$HOME/.secrets.tpl"
if command -v pass-cli &>/dev/null && [ -f "$_secrets_tpl" ]; then
  _resolved="$(pass-cli inject -i "$_secrets_tpl" 2>/dev/null)"
  if [ $? -eq 0 ] && [ -n "$_resolved" ]; then
    eval "$_resolved"
  fi
fi
unset _secrets_tpl _resolved
